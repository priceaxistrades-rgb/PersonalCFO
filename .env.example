# ═══════════════════════════════════════════════════════════════
# PersonalCFO — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, or local Postgres)
# Example: postgresql://user:password@host/database?sslmode=verify-full
DATABASE_URL=

# Session signing secret — MUST be a strong random string in production!
# Generate with: openssl rand -base64 32
# NEVER use the default value in production!
AUTH_SECRET=

# ─── Optional ──────────────────────────────────────────────────

# Distributed rate limiting for multi-instance production deployments.
# Recommended on Vercel/Railway when more than one app instance can run.
UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN

# Log level: debug | info | warn | error | fatal
# Default: "debug" in development, "info" in production
LOG_LEVEL=

# Node environment
# Default: "development"
NODE_ENV=

# ─── Email / Password Reset ──────────────────────────────────

# Base URL of your app (used for generating password reset links)
# Example: https://your-app.vercel.app
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# ─── Email Provider (optional — console mode is default) ─────
# To send real password reset emails, configure one of:
#
# Resend (recommended — free 100 emails/day):
#   1. Sign up at https://resend.com
#   2. Add and verify your sending domain
#   3. Set the vars below:
RESEND_API_KEY=
EMAIL_FROM="PersonalCFO <noreply@yourdomain.com>"
#
# Other providers: See src/lib/email.ts for integration points
# (SendGrid, Gmail SMTP with Nodemailer, etc.)
